<!DOCTYPE html>
<html>
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <style>
      body { background: #f9fafb; font-family: sans-serif; margin: 0; padding: 0; }
      .container { background: #ffffff; border-radius: 8px; margin: 40px auto; max-width: 520px; padding: 32px; }
      .header { border-bottom: 1px solid #e5e7eb; margin-bottom: 24px; padding-bottom: 16px; }
      .header h1 { color: #111827; font-size: 20px; margin: 0; }
      .status-accepted { color: #16a34a; font-weight: 600; }
      .status-rejected { color: #dc2626; font-weight: 600; }
      .detail-row { color: #374151; font-size: 14px; margin-bottom: 8px; }
      .detail-label { color: #6b7280; display: inline-block; min-width: 120px; }
      .footer { border-top: 1px solid #e5e7eb; color: #9ca3af; font-size: 12px; margin-top: 24px; padding-top: 16px; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1><%= t('mailer.heading') %></h1>
      </div>

      <p><%= t('mailer.greeting', name: @request.guest_name) %></p>

      <p class="<%= @reason == :accepted ? 'status-accepted' : 'status-rejected' %>"><%= @body %></p>
      <% if @custom_note %>
        <p style="color:#374151; margin-top: 8px;"><strong><%= t('mailer.note_from_nutritionist') %></strong> <%= @custom_note %></p>
      <% end %>

      <div style="background:#f3f4f6; border-radius:6px; margin: 20px 0; padding: 16px;">
        <div class="detail-row">
          <span class="detail-label"><%= t('mailer.nutritionist') %></span>
          <%= @nutritionist.name %>
        </div>
        <% if @service %>
          <div class="detail-row">
            <span class="detail-label"><%= t('mailer.service') %></span>
            <%= @service.name %>
          </div>
          <div class="detail-row">
            <span class="detail-label"><%= t('mailer.location') %></span>
            <%= @service.location %>
          </div>
        <% end %>
        <div class="detail-row">
          <span class="detail-label"><%= t('mailer.datetime') %></span>
          <%= @request.requested_at.strftime("%d %B %Y, %H:%M") %>
        </div>
      </div>

      <div class="footer">
        <%= t('mailer.footer') %>
      </div>
    </div>
  </body>
</html>
